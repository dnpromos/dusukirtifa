# Telegram Bot Token — @BotFather'dan alınır
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Aviasales/Travelpayouts API Token — https://www.travelpayouts.com/programs/100/tools/api
AVIASALES_API_TOKEN=your_aviasales_api_token

# SQLite veritabanı yolu (varsayılan: tele_flight.db)
DB_PATH=tele_flight.db

# Günlük bildirim saati (Türkiye saati, varsayılan: 09:00)
DAILY_ALERT_HOUR=9
DAILY_ALERT_MINUTE=0

# Wiro API (Gemini AI) — https://wiro.ai
WIRO_API_KEY=your_wiro_api_key
WIRO_API_SECRET=your_wiro_api_secret
